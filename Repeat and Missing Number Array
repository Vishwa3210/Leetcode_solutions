class Solution:
    # @param A : tuple of integers
    # @return a list of integers
    def repeatedNumber(self, A):
      n=len(A)
      count=[0]*(n+1)
      
      for i in A:
          count[i]=count[i]+1
          
      miss=0
      dup=0
      for num in range(1,n+1):
          if count[num]==0:
              miss=num
          if count[num]==2:
              dup=num
              
      return[miss,dup]
               
      
