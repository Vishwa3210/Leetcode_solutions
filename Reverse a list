class Solution:
    def reverseArray(self, arr):
        # code here
        i=0
        j=len(arr)-1
        for i in range(len(arr)):
            if i <j:
                arr[i],arr[j]=arr[j],arr[i]
                
                i=i+1
                j=j-1
                
            if i>j:
                break
            
        return arr
        
