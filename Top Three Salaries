with ranked as (select d.department_name, e.name, e.salary,
dense_rank() over(partition by d.department_name order by e.salary desc ) as rnk
from employee e 
left join department d 
on e.department_id=d.department_id)

select department_name,name,salary from ranked where rnk<=3 order by department_name asc, salary desc, name asc
