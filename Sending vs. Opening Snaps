SELECT 
    b.age_bucket,
    SUM(CASE WHEN a.activity_type = 'send' THEN a.time_spent ELSE 0 END) * 1.0 /
    SUM(CASE WHEN a.activity_type IN ('send','open') THEN a.time_spent ELSE 0 END) AS send_perc,
    
    SUM(CASE WHEN a.activity_type = 'open' THEN a.time_spent ELSE 0 END) * 1.0 /
    SUM(CASE WHEN a.activity_type IN ('send','open') THEN a.time_spent ELSE 0 END) AS open_perc

FROM activities a
JOIN age_breakdown b
ON a.user_id = b.user_id

GROUP BY b.age_bucket;
